{
  "meta": {
    "description": "Example OpenClaw configuration for local-only embedded testing with Ollama"
  },
  "env": {
    "shellEnv": {
      "enabled": false
    }
  },
  "browser": {
    "attachOnly": false
  },
  "models": {
    "providers": {
      "ollama": {
        "baseUrl": "http://127.0.0.1:11434/v1",
        "apiKey": "not-needed",
        "api": "openai-completions",
        "models": [
          {
            "id": "qwen2.5-coder:1.5b",
            "name": "Qwen 2.5 Coder 1.5B",
            "reasoning": false,
            "input": ["text"],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 32768,
            "maxTokens": 8192
          },
          {
            "id": "deepseek-coder:1.3b",
            "name": "DeepSeek Coder 1.3B",
            "reasoning": false,
            "input": ["text"],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 16384,
            "maxTokens": 4096
          },
          {
            "id": "llama3.2:1b",
            "name": "Llama 3.2 1B",
            "reasoning": false,
            "input": ["text"],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 131072,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "ollama/qwen2.5-coder:1.5b",
        "fallbacks": [
          "ollama/deepseek-coder:1.3b",
          "ollama/llama3.2:1b"
        ]
      },
      "models": {},
      "workspace": "/home/YOUR_USERNAME/.openclaw/workspace",
      "compaction": {
        "mode": "safeguard"
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      },
      "sandbox": {
        "mode": "all",
        "workspaceAccess": "ro",
        "scope": "session"
      }
    }
  },
  "messages": {
    "ackReactionScope": "group-mentions"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto"
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "REPLACE_WITH_YOUR_SECRET_TOKEN"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "nodes": {
      "denyCommands": [
        "camera.snap",
        "camera.clip",
        "screen.record",
        "calendar.add",
        "contacts.add",
        "reminders.add"
      ]
    }
  },
  "skills": {
    "allowBundled": ["*"],
    "load": {
      "watch": true
    },
    "install": {
      "preferBrew": false,
      "nodeManager": "npm"
    }
  }
}
